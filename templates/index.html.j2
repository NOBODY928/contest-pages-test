          item.name,
          contest_id,
          item.tags|default([])|join(' ')
        ] + (item.info_grid|default([])|map(attribute='value')|list))|join(' ') %}

        <article class="tile" data-id="{{ contest_id|e }}" data-key="{{ item.name|e }}" data-search="{{ search_text|lower|e }}" style="--delay: {{ i * 60 }}ms; --card-image: url('/static/images/{{ pokemon_img }}');">
          <div class="tile-bg"></div>

          <div class="tile-content">
            <div>
              <div class="tile-top">
                <div class="status-pill is-upcoming" data-status-pill>未开始</div>
                <div class="tile-actions">
                {% if official_url %}
                  <a class="btn" href="{{ official_url }}" target="_blank" rel="noopener noreferrer">查看官网</a>
                {% endif %}
                  {% if contest_id == 'cumcm' %}
                    <a class="btn" href="https://dxs.moe.gov.cn/zx/hd/sxjm/sxjmstjp/" target="_blank" rel="noopener noreferrer">赛题讲评</a>
                  {% endif %}
                </div>
              </div>

              <h2 class="tile-title">{{ item.name }}</h2>

              <div class="tags">
                {% if item.tags %}
                  {% for t in item.tags %}
                    <span class="tag">#{{ t }}</span>
                  {% endfor %}
                {% endif %}
              </div>

              <p class="tile-sub">
                {# “最新动态”优先取 info_grid 里 label=最新动态 的 value；拿不到就用默认文案 #}
                {% set latest = none %}
                {% if item.info_grid %}
                  {% for g in item.info_grid %}
                    {% if g.label == '最新动态' %}
                      {% set latest = g.value %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
                {{ latest if latest else '点击官网查看最新信息…' }}
              </p>
            </div>
            <button class="favorite-btn" type="button" data-favorite-btn aria-pressed="false">&#9734; &#25910;&#34255;</button>
          </div>
        </article>
      {% endfor %}
      <div id="noResults" class="no-results">未找到匹配的竞赛</div>
    </div>
  </div>
  <script>
    (() => {
      const input = document.getElementById('contestSearch');
      const searchArea = document.querySelector('.search-area');
      const filterActions = document.getElementById('filterActions');
      const activeFilterBtn = document.getElementById('activeFilterBtn');
      const favoriteFilterBtn = document.getElementById('favoriteFilterBtn');
      const cards = Array.from(document.querySelectorAll('.tile'));
      const empty = document.getElementById('noResults');
      const favoriteStorageKey = 'favorite_contests';
      let showActiveOnly = false;
      let showFavoritesOnly = false;
      let favoriteIds = [];
      const activeUntilMap = {
        cpipc_math_modeling: '2026-08-16',
        cpipc_electronics: '2026-08-16',
        cpipc_chips: '2026-08-16',
        cpipc_rural_revitalization: '2026-08-16',
        cpipc_fintech: '2026-08-16',
        cpipc_aircraft: '2026-08-16',
        cpipc_ai: '2026-08-16',
        cpipc_cyber_security: '2026-08-16',
        challenge_cup_startup: '2026-08-16',
        software_design: '2026-08-16',
        iot_design: '2026-08-16',
        xuechuang_cup: '2026-08-16',
        statistics_modeling: '2026-08-16',
        software_cup: '2026-08-16',
        photo_design: '2026-08-16',
        embedded_chip: '2026-08-16'
      };
      const endedUntilMap = {
        cpipc_public_admin: '2026-08-16',
        icpc: '2026-08-16',
        info_security_ctf: '2026-08-16'
      };
      const statusLabels = {
        active: '正在进行',
        ended: '已结束',
        upcoming: '未开始'
      };
      const statusClasses = ['is-active', 'is-ended', 'is-upcoming'];

      const normalize = (value) => value.toLowerCase().trim();
      const readFavorites = () => {
        try {
          const parsed = JSON.parse(localStorage.getItem(favoriteStorageKey) || '[]');
          return Array.isArray(parsed) ? parsed.filter((id) => typeof id === 'string') : [];
        } catch (error) {
          return [];
        }
      };
      const writeFavorites = () => {
        localStorage.setItem(favoriteStorageKey, JSON.stringify(favoriteIds));
      };
      const isFavorite = (id) => favoriteIds.includes(id);
      const parseDate = (value) => {
        const [year, month, day] = value.split('-').map(Number);
        return new Date(year, month - 1, day, 23, 59, 59, 999);
      };
      const addMonths = (date, months) => {
        const next = new Date(date);
        next.setMonth(next.getMonth() + months);
        return next;
      };
      const resolveStatus = (id, now) => {
        if (activeUntilMap[id]) {
          const activeUntil = parseDate(activeUntilMap[id]);
          if (now <= activeUntil) return 'active';
          if (now <= addMonths(activeUntil, 2)) return 'ended';
          return 'upcoming';
        }

        if (endedUntilMap[id]) {
          const endedUntil = parseDate(endedUntilMap[id]);
          return now <= endedUntil ? 'ended' : 'upcoming';
        }

        return 'upcoming';
      };
      const applyStatuses = () => {
        const now = new Date();
        cards.forEach((card) => {
          const pill = card.querySelector('[data-status-pill]');
          if (!pill) return;

          const status = resolveStatus(card.dataset.id || '', now);
          card.dataset.status = status;
          pill.textContent = statusLabels[status];
          pill.classList.remove(...statusClasses);
          pill.classList.add(`is-${status}`);
        });
      };
      const updateFavoriteButton = (card) => {
        const button = card.querySelector('[data-favorite-btn]');
        if (!button) return;

        const favorited = isFavorite(card.dataset.id || '');
        button.textContent = favorited ? '\u2605 \u5df2\u6536\u85cf' : '\u2606 \u6536\u85cf';
        button.classList.toggle('is-favorite', favorited);
        button.setAttribute('aria-pressed', String(favorited));
      };
      const applyFavorites = () => {
        cards.forEach(updateFavoriteButton);
      };
      const syncFilterButtons = () => {
        activeFilterBtn.classList.toggle('is-active-filter', showActiveOnly);
        activeFilterBtn.textContent = showActiveOnly ? '\u2713 \u8fdb\u884c\u4e2d' : '\u8fdb\u884c\u4e2d';
        activeFilterBtn.setAttribute('aria-pressed', String(showActiveOnly));

        favoriteFilterBtn.classList.toggle('is-favorite-filter', showFavoritesOnly);
        favoriteFilterBtn.textContent = showFavoritesOnly ? '\u2605 \u6536\u85cf' : '\u6536\u85cf';
        favoriteFilterBtn.setAttribute('aria-pressed', String(showFavoritesOnly));
      };

      const filterCards = () => {
        const query = normalize(input.value);
        let visibleCount = 0;

        cards.forEach((card) => {
          const haystack = card.dataset.search || '';
          const id = card.dataset.id || '';
          const matchedSearch = !query || haystack.includes(query);
          const matchedActive = !showActiveOnly || card.dataset.status === 'active';
          const matchedFavorite = !showFavoritesOnly || isFavorite(id);
          const matched = matchedSearch && matchedActive && matchedFavorite;
          card.classList.toggle('is-hidden', !matched);
          if (matched) visibleCount += 1;
        });

        empty.classList.toggle('is-visible', visibleCount === 0);
      };

      if (searchArea && filterActions) {
        searchArea.appendChild(filterActions);
      }

      favoriteIds = readFavorites();
      applyStatuses();
      applyFavorites();
      syncFilterButtons();
      filterCards();

      input.addEventListener('input', filterCards);
      activeFilterBtn.addEventListener('click', () => {
        showActiveOnly = !showActiveOnly;
        syncFilterButtons();
        filterCards();
      });
      favoriteFilterBtn.addEventListener('click', () => {
        showFavoritesOnly = !showFavoritesOnly;
        syncFilterButtons();
        filterCards();
      });
      cards.forEach((card) => {
        const button = card.querySelector('[data-favorite-btn]');
        if (!button) return;

        button.addEventListener('click', () => {
          const id = card.dataset.id || '';
          if (!id) return;

          favoriteIds = isFavorite(id)
            ? favoriteIds.filter((favoriteId) => favoriteId !== id)
            : [...favoriteIds, id];
          writeFavorites();
          updateFavoriteButton(card);
          filterCards();
        });
      });
    })();
  </script>
</body>
</html>
