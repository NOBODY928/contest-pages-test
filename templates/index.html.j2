<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>竞赛资讯聚合</title>

  <style>
    :root{
      --bg: #f5f5f7;
      --text: #1d1d1f;
      --sub: #6e6e73;
      --card-radius: 28px;
      --shadow: 0 18px 50px rgba(0,0,0,.10);
      --shadow-hover: 0 26px 70px rgba(0,0,0,.16);
      --blue: #0071e3;
    }

    *{ box-sizing: border-box; }
    body{
      margin:0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      -webkit-font-smoothing: antialiased;
      padding: 26px 18px 60px;
    }

    /* 顶部区域：尽量 Apple 风 */
    .topbar{
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:16px;
      max-width: 1600px;
      margin: 0 auto 18px;
      padding: 0 6px;
    }
    .title{
      line-height:1.05;
    }
    .title h1{
      margin:0;
      font-size: 44px;
      letter-spacing:-0.03em;
      font-weight:800;
    }
    .title .hint{
      margin-top:10px;
      color:var(--sub);
      font-size:13px;
    }
    .meta{
      text-align:right;
      color:var(--sub);
      font-size:13px;
      display:flex;
      flex-direction:column;
      gap:10px;
      align-items:flex-end;
    }
    .pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,.65);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(0,0,0,.06);
    }
    .pill b{ color:var(--text); font-weight:700; }

    .search-area{
      display:flex;
      align-items:center;
      gap:12px;
      max-width: 980px;
      margin: 0 auto 20px;
      padding: 0 6px;
    }
    .search-input{
      flex:1 1 auto;
      min-width:0;
      width:100%;
      height:52px;
      border:1px solid rgba(0,0,0,.08);
      border-radius: 999px;
      padding: 0 22px;
      background: rgba(255,255,255,.78);
      box-shadow: 0 12px 34px rgba(0,0,0,.08);
      color: var(--text);
      font: inherit;
      font-size: 16px;
      outline: none;
      backdrop-filter: blur(12px);
    }
    .search-input:focus{
      border-color: rgba(0,113,227,.45);
      box-shadow: 0 0 0 4px rgba(0,113,227,.12), 0 12px 34px rgba(0,0,0,.08);
    }
    .search-input::placeholder{
      color: rgba(110,110,115,.78);
    }
    .filter-actions{
      display:flex;
      align-items:center;
      gap:10px;
      flex:0 0 auto;
    }
    .filter-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      height:52px;
      min-width:94px;
      padding:0 18px;
      border:1px solid rgba(0,0,0,.08);
      border-radius:999px;
      background:rgba(255,255,255,.78);
      color:var(--sub);
      box-shadow:0 12px 34px rgba(0,0,0,.08);
      cursor:pointer;
      font:inherit;
      font-size:15px;
      font-weight:800;
      white-space:nowrap;
      backdrop-filter:blur(12px);
    }
    .filter-btn:hover{
      background:rgba(255,255,255,.92);
    }
    .filter-btn.is-active-filter{
      background:#A8F0B2;
      color:#0B5D1E;
      border-color:rgba(11,93,30,.18);
    }
    .filter-btn.is-favorite-filter{
      background:#FFD966;
      color:#6B4F00;
      border-color:rgba(107,79,0,.18);
    }

    /* 统一尺寸的信息卡片墙 */
    .wrap{
      max-width: 1600px;
      margin: 0 auto;
    }
    .masonry{
      display:grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 22px;
      padding: 10px 6px 0;
    }
    .no-results{
      display:none;
      grid-column: 1 / -1;
      min-height: 180px;
      align-items:center;
      justify-content:center;
      color: var(--sub);
      font-size: 18px;
      font-weight: 700;
      background: rgba(255,255,255,.72);
      border:1px solid rgba(0,0,0,.06);
      border-radius: var(--card-radius);
      box-shadow: var(--shadow);
    }
    .no-results.is-visible{
      display:flex;
    }

    /* 响应式：大屏3列，中屏2列，手机1列 */
    @media (max-width: 980px){
      .title h1{ font-size:36px; }
      .masonry{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 640px){
      .topbar{ align-items:flex-start; flex-direction:column; }
      .meta{ align-items:flex-start; text-align:left; }
      .search-area{ align-items:stretch; flex-direction:column; }
      .filter-actions{ width:100%; }
      .filter-btn{ flex:1 1 0; min-width:0; }
      .masonry{ grid-template-columns: minmax(0, 1fr); gap:16px; }
    }

    /* 卡片：整张背景图铺满（cover） */
    .tile{
      position:relative;
      border-radius: var(--card-radius);
      overflow:hidden;
      min-height: 360px;
      height: 360px;
      box-shadow: var(--shadow);
      transform: translateY(18px);
      opacity: 0;
      animation: enter .72s cubic-bezier(.2,.8,.2,1) forwards;
      animation-delay: var(--delay, 0ms);
      background: #eef1f6;
    }
    .tile.is-hidden{
      display:none;
    }

    @keyframes enter{
      to{ transform: translateY(0); opacity:1; }
    }

    .tile:hover{
      transform: translateY(-6px);
      box-shadow: var(--shadow-hover);
      transition: transform .28s ease, box-shadow .28s ease;
    }

    /* 背景层：图片 + 叠加渐变（确保文字可读） */
    .tile-bg{
      position:absolute;
      inset:0;
      background-image: var(--card-image);
      background-size: contain;
      background-position: center;
      background-repeat:no-repeat;
      filter: saturate(1.05);
      transform: scale(.86);
    }
    .tile::after{
      content:"";
      position:absolute;
      inset:0;
      /* Apple常用：上浅下深，文本区域可读 */
      background:
        linear-gradient(180deg,
          rgba(0,0,0,.10) 0%,
          rgba(0,0,0,.18) 35%,
          rgba(0,0,0,.50) 78%,
          rgba(0,0,0,.62) 100%);
      pointer-events:none;
    }

    /* 内容层 */
    .tile-content{
      position:absolute;
      inset:0;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      padding: 22px 22px 18px;
      z-index:2;
      color:#fff;
    }

    .tile-top{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
    }

    .status-pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width: 82px;
      height: 34px;
      padding: 0 14px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 900;
      line-height:1;
      text-align:center;
      box-shadow: 0 8px 18px rgba(0,0,0,.16);
      border: 1px solid rgba(255,255,255,.5);
      white-space: nowrap;
    }
    .status-pill.is-active{
      background:#A8F0B2;
      color:#0B5D1E;
    }
    .status-pill.is-ended{
      background:#FF9B9B;
      color:#7A1010;
    }
    .status-pill.is-upcoming{
      background:#E5E7EB;
      color:#374151;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      padding: 10px 14px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 13px;
      text-decoration:none;
      color:#0b1b2b;
      background: rgba(255,255,255,.78);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,.35);
    }
    .btn:hover{
      background: rgba(255,255,255,.92);
    }
    .tile-actions{
      display:flex;
      flex-direction:column;
      align-items:flex-end;
      gap:12px;
    }
    .favorite-btn{
      position:absolute;
      right:22px;
      bottom:18px;
      z-index:3;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:94px;
      height:38px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.35);
      background:rgba(255,255,255,.78);
      color:#0b1b2b;
      backdrop-filter:blur(10px);
      cursor:pointer;
      font:inherit;
      font-size:13px;
      font-weight:800;
      white-space:nowrap;
    }
    .favorite-btn:hover{
      background:rgba(255,255,255,.92);
    }
    .favorite-btn.is-favorite{
      background:#FFD966;
      color:#6B4F00;
      border-color:rgba(255,255,255,.45);
    }

    .tags{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top: 10px;
    }
    .tag{
      font-size: 12px;
      font-weight: 700;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.22);
      backdrop-filter: blur(10px);
    }

    .tile-title{
      margin: 10px 0 8px;
      font-size: 28px;
      font-weight: 900;
      letter-spacing: -0.02em;
      line-height: 1.15;
      text-shadow: 0 6px 18px rgba(0,0,0,.25);
    }
    .tile-sub{
      margin:0;
      opacity:.92;
      font-size: 14px;
      line-height: 1.45;
      max-width: 92%;
    }

    .ref{
      font-size: 12px;
      opacity: .65;
      font-weight: 700;
      letter-spacing: .06em;
    }

    @media (max-width: 640px){
      .tile-title{ font-size:22px; }
      .tile{ min-height: 320px; height: 320px; }
    }

    /* 没有图时的默认底图（也像 Apple 的灰色占位） */
    .fallback-bg{
      background:
        radial-gradient(1200px 500px at 30% 20%, rgba(255,255,255,.55), rgba(255,255,255,0)),
        linear-gradient(135deg, #cfcfd6, #9f9faa);
    }
  </style>
</head>

<body>
  <div class="topbar">
    <div class="title">
      <h1>竞赛资讯聚合</h1>
      <div class="hint">数据源为公开页面抓取整理；若展示异常，优先以官网为准。</div>
    </div>

    <div class="meta">
      <div class="pill">
        <span>最后更新：</span>
        <b>{{ updated_at or '' }}</b>
      </div>
      <div>
        托管于 <a href="https://pages.cloudflare.com/" target="_blank" rel="noopener" style="color:var(--blue); text-decoration:none; font-weight:800;">Cloudflare Pages</a>
      </div>
    </div>
  </div>

  <div class="search-area">
    <input id="contestSearch" class="search-input" type="search" placeholder="搜索竞赛名称、标签、关键词..." autocomplete="off" />
  </div>

  <div id="filterActions" class="filter-actions">
    <button id="activeFilterBtn" class="filter-btn" type="button" aria-pressed="false">&#36827;&#34892;&#20013;</button>
    <button id="favoriteFilterBtn" class="filter-btn" type="button" aria-pressed="false">&#25910;&#34255;</button>
  </div>

